{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Type Check",
      "type": "shell",
      "command": "bun",
      "args": ["run", "typecheck"],
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Start",
      "type": "shell",
      "command": "bun",
      "args": ["start", "--", "${input:dayArgs}"],
      "problemMatcher": []
    },
    {
      "label": "Watch",
      "type": "shell",
      "command": "bun",
      "args": ["watch", "--", "${input:dayArgs}"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "dayArgs",
      "type": "promptString",
      "description": "Enter day arguments (e.g., 'day 1')",
      "default": "day 1"
    }
  ]
}
