{
  "name": "adventofcode2025",
  "version": "1.0.0",
  "description": "Advent of Code 2025 solutions using Bun and Effect-TS",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "day01": "bun run src/days/day01/index.ts",
    "day01:watch": "bun --watch run src/days/day01/index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@effect/platform": "^0.93.6",
    "@effect/platform-bun": "^0.86.0",
    "effect": "^3.19.8"
  }
}
