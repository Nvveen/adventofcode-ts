{
  "name": "adventofcode2025",
  "version": "1.0.0",
  "description": "Advent of Code 2025 solutions using Bun and Effect-TS",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@effect/cli": "latest",
    "@effect/platform": "latest",
    "@effect/platform-bun": "latest",
    "effect": "latest"
  }
}
